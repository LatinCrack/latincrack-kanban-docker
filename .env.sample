# ---------------------------------------------------------
# CONFIGURACIÓN PARA LATINCRACK KANBAN (DOCKER)
# ---------------------------------------------------------

# Interruptor maestro para usar la arquitectura de 3 capas
VITE_USE_DOCKER=true

# La IP de tu VPS (DigitalOcean/Linode) + Puerto de la API
VITE_API_URL=http://TU_IP_ACA:3000/api

# ---------------------------------------------------------
# VALORES "DUMMY" (OBLIGATORIOS PARA EVITAR CRASH)
# Estos valores no se usan, pero React los busca al arrancar.
# No borrarlos hasta limpiar supabase.js por completo.
# ---------------------------------------------------------
VITE_SUPABASE_URL=https://dummy.supabase.co
VITE_SUPABASE_ANON_KEY=dummy-key-para-evitar-error